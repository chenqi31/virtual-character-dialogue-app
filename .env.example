# 服务监听端口
PORT=7001

# 大模型（minimax）配置
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat

# 数据库：dev 用 mysql（与 docker/.env 配合），prod 用 sqlite
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=virtual_chat
DB_PASSWORD=virtual_chat
DB_NAME=virtual_chat
DB_SQLITE_PATH=

# 桌面端用户数据目录（运行期写入，build 时不使用）
USER_DATA_DIR=
